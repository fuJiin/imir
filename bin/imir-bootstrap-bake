#!/bin/bash
set -euo pipefail

DEV_USER="dev"

echo "=== Imir Bake: System Setup ==="

# Wait for cloud-init to finish (may hold apt lock)
echo "Waiting for cloud-init..."
cloud-init status --wait 2>/dev/null || true

# ── System packages ────────────────────────────────────────────────

echo "Adding GitHub CLI apt repository..."
mkdir -p -m 755 /etc/apt/keyrings
curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    -o /etc/apt/keyrings/githubcli-archive-keyring.gpg
chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list

echo "Installing system packages..."
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y \
    git \
    gh \
    tmux \
    curl \
    unzip

# ── Dev user ───────────────────────────────────────────────────────

if ! id "$DEV_USER" &>/dev/null; then
    echo "Creating user: $DEV_USER"
    useradd -m -s /bin/bash -G sudo "$DEV_USER"
    echo "$DEV_USER ALL=(ALL) NOPASSWD:ALL" > "/etc/sudoers.d/$DEV_USER"
    chmod 440 "/etc/sudoers.d/$DEV_USER"
fi

# Tell cloud-init to treat dev as the default user so it preserves
# the home directory (and everything baked into it) across snapshot boots.
cat > /etc/cloud/cloud.cfg.d/99-imir.cfg <<CLOUD
system_info:
  default_user:
    name: $DEV_USER
    shell: /bin/bash
    groups: [sudo]
    sudo: ALL=(ALL) NOPASSWD:ALL
CLOUD

# ── Claude Code ────────────────────────────────────────────────────

echo "Installing Claude Code..."
sudo -u "$DEV_USER" bash -c 'curl -fsSL https://claude.ai/install.sh | bash'

# ── User bake hook ─────────────────────────────────────────────────

if [[ -f /tmp/imir-bake-hook ]]; then
    echo "Running bake hook..."
    bash /tmp/imir-bake-hook
fi

echo "=== Bake complete ==="
